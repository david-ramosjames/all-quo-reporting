# ── Quo API ───────────────────────────────────────────────────────────────────
QUO_API_KEY=your_api_key_here

# Lines to include (comma-separated name, number, or PN id). Blank = all lines.
# Examples: Intake   or   Intake,RJL Main Line   or   +15126010647
QUO_PHONE_NUMBERS=
# When QUO_PHONE_NUMBERS is non-empty, weekly + monthly runs **merge** these extra lines (names or E.164).
# Default in code if unset: RJL Outbound (+15125005266), RJL Transfers (+15126300907). Set to empty to disable: QUO_PHONE_NUMBERS_WEEKLY_MONTHLY_EXTRA=
# QUO_PHONE_NUMBERS_WEEKLY_MONTHLY_EXTRA=RJL Outbound,+15125005266,RJL Transfers,+15126300907

# Optional date filters (ISO 8601). Blank = no filter (weekly report sets these automatically)
QUO_CREATED_AFTER=
QUO_CREATED_BEFORE=
# Weekly + monthly list /v1/conversations by last activity (updatedAfter/updatedBefore) for that window, not by thread createdAt — otherwise long-lived client numbers vanish from the export even when Quo shows recent calls.

QUO_MAX_RESULTS=100


# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Default: gpt-5-mini (high context + TPM). Fallback if unavailable: gpt-4o-mini
OPENAI_MODEL=gpt-5-mini
# GPT-5 can spend tokens on hidden "reasoning" — if the email body is empty, raise this (default 28000).
OPENAI_MAX_COMPLETION_TOKENS=28000
# Optional: cap for Daily Lead Report (defaults to OPENAI_MAX_COMPLETION_TOKENS).
# OPENAI_LEAD_REPORT_MAX_COMPLETION_TOKENS=28000
# Per-client weekly bundle (summaries + SMS log can be large). Default 8192 in code — raise if JSON validation fails.
# OPENAI_SENTIMENT_MAX_COMPLETION_TOKENS=8192
# Monthly: per-transcript newsletter theme JSON. Default 8192.
# OPENAI_MONTHLY_EXTRACTION_MAX_COMPLETION_TOKENS=8192
# Monthly: how many voice rows per batched extraction request (default 40; max 60). Use 1 for one LLM call per call.
# MONTHLY_EXTRACTION_BATCH_SIZE=40
# Monthly batch: use OpenAI strict json_schema so batched JSON matches (default on). Set 0 to force legacy json_object only.
# MONTHLY_BATCH_USE_JSON_SCHEMA=1
# Monthly: run this many batch requests in parallel (default 3; max 10). Raise carefully if OpenAI rate-limits.
# MONTHLY_EXTRACTION_CONCURRENCY=3
# Pause in ms between parallel **waves** of monthly extraction (default 60; weekly uses SENTIMENT_LLM_DELAY_MS).
# MONTHLY_LLM_DELAY_MS=60
# Monthly: truncate transcripts inside batched prompts only (per call; summaries unchanged). 0 = no cap.
# MONTHLY_BATCH_TRANSCRIPT_MAX_CHARS=1200
# Optional: override completion token cap for batched monthly extraction (else scales with batch size, max 32000).
# OPENAI_MONTHLY_BATCH_MAX_COMPLETION_TOKENS=16000
# Monthly: deduped newsletter email from all extractions. Default 20000.
# OPENAI_MONTHLY_AGGREGATE_MAX_COMPLETION_TOKENS=20000
# Monthly: max transcripts included in the aggregation prompt (after all are processed). Default 200.
# MONTHLY_AGGREGATE_DIGEST_MAX_TRANSCRIPTS=200
# Monthly: cap how many calls are processed (0 = all). For cost testing only. (Env name still says TRANSCRIPTS.)
# MONTHLY_MAX_TRANSCRIPTS_TO_PROCESS=0
# Monthly: set true to fetch full call transcripts in addition to summaries (slower, more tokens).
# MONTHLY_FETCH_TRANSCRIPTS=false
# Pause between per-transcript OpenAI calls (ms). Default 120.
# SENTIMENT_LLM_DELAY_MS=120
# low | medium | high — lower = more tokens left for visible report text (Chat Completions API)
OPENAI_REASONING_EFFORT=low

# Used in the LLM prompt so it knows whose calls it's analyzing
COMPANY_NAME=Your Company


# ── Email ─────────────────────────────────────────────────────────────────────
# Who the report is sent from and to (comma-separated for multiple recipients)
EMAIL_FROM=david@ramosjames.com
EMAIL_TO=

# Email is sent via the Gmail API (HTTPS) using the same GOOGLE_CLIENT_ID /
# GOOGLE_CLIENT_SECRET / GOOGLE_REFRESH_TOKEN values used for Sheets (below).
# Run `node setup-sheets-auth.js` once to mint a refresh token with both
# spreadsheets + gmail.send scopes. EMAIL_FROM must be the Gmail mailbox
# that authorized the token.

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Cron: minute hour day-of-month month day-of-week (evaluated in TIMEZONE).
# Defaults below: daily 07:00, weekly Fri 20:00, monthly 1st 01:00 — all America/Chicago (Central).
CRON_SCHEDULE=0 7 * * *
# Weekly client sentiment (trailing 7 days). 5 = Friday in node-cron.
WEEKLY_SENTIMENT_CRON=0 20 * * 5
# Monthly newsletter insights (trailing 30 days): 01:00 on the 1st of each month.
MONTHLY_INSIGHTS_CRON=0 1 1 * *
# Review Intelligence (trailing 24h): daily 18:00 (6:00 PM) Central — Google review candidates.
REVIEW_INTELLIGENCE_CRON=0 18 * * *

# Your timezone — defines "yesterday" for calls AND Slack + when crons run (must match firm)
TIMEZONE=America/Chicago

# ── Manual trigger web UI (runs inside scheduler.js on PORT) ──────────────────
# The dashboard (/) and the review editor (/review/edit) are gated by Google
# sign-in — configure it in the "Review editor access" section below. Without it,
# those pages are locked (the public /review page and /health stay open; crons
# keep running either way).
# Railway sets PORT when the service has networking. Local default if unset: 8787.
# PORT=8787
# Set to true to keep scheduler-only with no HTTP listener.
# DISABLE_MANUAL_TRIGGER_UI=false


# ── Slack (#lead-calls) ───────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=lead-calls
SLACK_INCLUDE_THREADS=true


# ── Google Sheets (OAuth — run node setup-sheets-auth.js) ─────────────────────
# Spreadsheets read/write only (weekly log writes). Re-run after scope changes; revoke old app access if needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEETS_ID=
# Target a specific tab + columns, e.g. Leads!A:ZZ (recommended if pipeline is not the first sheet).
# Leave blank for entire first worksheet only. Tab names with spaces: 'My Tab'!A:ZZ
GOOGLE_SHEETS_RANGE=Leads!A:ZZ
# Leave blank to send every data row to the LLM. Set a number to cap (saves tokens).
GOOGLE_SHEETS_MAX_ROWS=
# Which columns hold name / phone / status / consultation Y|N (Excel letters).
GOOGLE_SHEETS_NAME_COL=E
GOOGLE_SHEETS_PHONE_COL=F
GOOGLE_SHEETS_STATUS_COL=K
GOOGLE_SHEETS_CONSULT_COL=L

# Optional: weekly client-sentiment email — matter → lead attorney + paralegal (same OAuth as above).
# Spreadsheet must be shared with the Google account used for setup-sheets-auth.js.
# Case column must be numeric text (matches the digits at the end of the Quo contact name, e.g. … 1048).
GOOGLE_SHEETS_CASE_ROSTER_ID=1mkh1XjKiWScNm4rEXdHdIdQdL0w_7MwIEVHJw1VEMfM
# Entire first tab, or e.g. Sheet1!A:E to limit columns fetched.
GOOGLE_SHEETS_CASE_ROSTER_RANGE=
# Defaults: A = case #, C = lead attorney, E = paralegal
# GOOGLE_SHEETS_CASE_ROSTER_CASE_COL=A
# GOOGLE_SHEETS_CASE_ROSTER_ATTORNEY_COL=C
# GOOGLE_SHEETS_CASE_ROSTER_PARALEGAL_COL=E

# Optional: append weekly client sentiment table to a **dedicated** tab (new rows each week under existing data).
# Uses the same OAuth as above. Create a blank tab first; leave A1 empty so the first run writes the column header.
# GOOGLE_WEEKLY_SENTIMENT_SHEET_ID=
# Tab + columns anchor (append fills downward). Blank = first worksheet. You may use tab only: Sheet1
# Examples: Sheet1   or   Sheet1!A:Q   or   'Weekly sentiment'!A:Q
# GOOGLE_WEEKLY_SENTIMENT_RANGE=
# 0 = append-only every run. Default on: upsert per (Quo window + client) — refresh row if client is in this run;
#     clients not in this run keep old rows; extra duplicate rows for the same client+window are deleted.
# GOOGLE_WEEKLY_SENTIMENT_DEDUPE=1
# How many rows to scan from row 2 when upserting (default 8000).
# GOOGLE_WEEKLY_SENTIMENT_SCAN_MAX_ROWS=8000

# Weekly negative email snapshot: **replaces** all data rows on this tab each run (header + current + carryover).
# Defaults to spreadsheet GOOGLE_WEEKLY_SENTIMENT_SHEET_ID and tab **Negative Sentiment** (create that tab once).
# GOOGLE_WEEKLY_NEGATIVE_SENTIMENT_SHEET_ID=
# GOOGLE_WEEKLY_NEGATIVE_SENTIMENT_RANGE=Negative Sentiment


# ── Review Intelligence V1 (daily Google-review candidate detection) ──────────
# Daily at REVIEW_INTELLIGENCE_CRON (default 6:00 PM CST): read the last 24h of
# client communications (Quo calls + SMS), evaluate each active client's overall
# journey, score them 0–100 as a Google-review candidate, save qualified clients
# to the review_opportunities table, and post the highest-confidence picks to Slack.
#
# Slack channel for the daily report (bot must be a member). Uses SLACK_BOT_TOKEN above.
REVIEW_SLACK_CHANNEL=review-opportunities
# How many days of journey context to read per client (the 24h window still gates who is scored).
# REVIEW_JOURNEY_DAYS=14
# Minimum score to record a Review Opportunity in the table.
# REVIEW_MIN_SCORE=60
# The Slack report only surfaces the very best — a standout, genuinely positive
# moment (any case stage). Defaults: score >= 90 AND High confidence. Lower them
# (e.g. 80) to also catch strong-but-softer candidates.
# REVIEW_REPORT_MIN_SCORE=90
# REVIEW_REPORT_MIN_CONFIDENCE=High     # High | Medium | Low (floor)
# REVIEW_REPORT_LIMIT=10
# OPENAI_REVIEW_MAX_COMPLETION_TOKENS=4096

# Backend table "review_opportunities" (a dedicated tab; same Google OAuth as the sheets above).
# Create a blank tab named review_opportunities and leave A1 empty so the first run writes the header:
#   id | case_id | client_name | review_score | confidence | reasoning | status | created_at | updated_at | sent_at
# Leave GOOGLE_REVIEW_OPPORTUNITIES_SHEET_ID unset to skip persistence (Slack report still posts).
# GOOGLE_REVIEW_OPPORTUNITIES_SHEET_ID=
# GOOGLE_REVIEW_OPPORTUNITIES_RANGE=review_opportunities

# ── Trackable review links + analytics + firm settings ────────────────────────
# The review system stores three more tabs in ONE spreadsheet (auto-created on
# first use): firm_settings, review_requests, review_request_events. Point this
# at that spreadsheet (or reuse GOOGLE_REVIEW_OPPORTUNITIES_SHEET_ID). Same OAuth.
# GOOGLE_REVIEW_SHEET_ID=
#
# When a client qualifies, a review_request with a short URL-safe token is
# created and the branded link is posted to Slack:  https://<domain>/r/<token>
# Opening the link and each button (Google/Text/Call) is tracked; see /review/analytics.
#
# Public base used to build absolute links (branded domain preferred). If unset,
# links fall back to the request Host. Do NOT send the raw Railway URL to clients.
# REVIEW_PUBLIC_BASE_URL=https://reviews.ramosjames.com
# The firm's branded review domain (also resolves branding by Host). See RAILWAY.md.
# REVIEW_DOMAIN=reviews.ramosjames.com
# REVIEW_TOKEN_LENGTH=10
# Salt for hashing visitor IPs (raw IPs are never stored). Set to a random string.
# REVIEW_IP_HASH_SALT=change-me

# ── Approval-to-send: staff approve in Slack, then the client is texted ───────
# Review Intelligence NEVER auto-texts. It posts one Slack message per candidate;
# a staff ✅ reaction (or a threaded "approve" reply) texts that client the link.
# Requires Slack Event Subscriptions (see RAILWAY.md) + the Quo sending line.
# SLACK_SIGNING_SECRET=            # from the Slack app's Basic Information page
# REVIEW_APPROVE_EMOJI=white_check_mark   # reaction that triggers a send
# The Quo/OpenPhone line to send from — E.164 (+15125005266) or a PN id. Uses QUO_API_KEY.
# QUO_SEND_FROM=
# SMS body is editable in the admin (/review/edit → "Review text message"). This
# env var is only a fallback default. Tokens: {first} {firm} {link}
# REVIEW_SMS_TEMPLATE=Hi {first}, thank you for trusting {firm}. If we made a difference, a quick Google review would mean a lot: {link}
# One-off / test texts: /review/analytics → "One-off / test text" (any number + message).

# ── Datastore: Postgres (recommended) or Google Sheets ────────────────────────
# If DATABASE_URL is set (e.g. a Railway Postgres plugin), firm_settings +
# review_requests + review_request_events use Postgres (atomic click counters,
# tables auto-created). Otherwise they fall back to the Google Sheet above.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# PG_SSL=require            # set to 0/disable to turn SSL off (e.g. local Postgres)

# ── Admin access: Google sign-in ─────────────────────────────────────────────
# Gates BOTH the manual-trigger dashboard (/) and the review editor (/review/edit).
# The public page /review and /health stay open. Set the vars below to restrict
# admin access to your people; without them, those admin pages are locked.
#
# IMPORTANT: create a **Web application** OAuth client in Google Cloud Console
# (the setup-sheets-auth.js client is a Desktop client and will NOT work here).
# Add this Authorized redirect URI to that Web client:
#     https://all-quo-reporting-production.up.railway.app/review/auth/callback
# GOOGLE_OAUTH_CLIENT_ID=xxxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=
# Who may edit — either an explicit email allowlist, a Workspace domain, or both:
# REVIEW_ADMIN_EMAILS=laura@ramosjames.com,david@ramosjames.com
# REVIEW_ADMIN_DOMAIN=ramosjames.com
# Signs the login session cookie. If unset, a random per-process secret is used
# (fine, but everyone is logged out on each redeploy — set this to keep sessions).
# REVIEW_SESSION_SECRET=
# REVIEW_SESSION_TTL_HOURS=12
# Only needed if header-derived URL is wrong (e.g. behind extra proxies):
# REVIEW_AUTH_BASE_URL=https://all-quo-reporting-production.up.railway.app

# ── Review landing page (served at /review by the scheduler's HTTP server) ────
# Branded, mobile-first Google-review page. Edit it three ways (later wins):
#   1) review-landing.json,
#   2) the token-gated admin editor at /review/edit (writes that file),
#   3) the env vars below (override the file — best on ephemeral hosts).
# Only Google reviews are supported in V1 (no Yelp/Facebook, no auto-send).
#
# Personalize the headline per client with a query param, e.g.
#   /review?name=Maria   ->   "Thank you, Maria."
#
# Persistence: the editor writes to review-landing.json. On Railway (ephemeral FS)
# that resets on redeploy, so either set the env vars below OR mount a volume and
# point REVIEW_LANDING_CONFIG_PATH at a file on it so edits survive redeploys.
# REVIEW_LANDING_CONFIG_PATH=/data/review-landing.json
#
# REVIEW_GOOGLE_URL=https://search.google.com/local/writereview?placeid=YOUR_PLACE_ID
# REVIEW_PAGE_HEADLINE=Thank you for choosing Ramos James.
# REVIEW_PAGE_BODY=Most people find us during one of the most stressful moments of their lives...
# REVIEW_PAGE_BUTTON_TEXT=Leave a Google Review
# REVIEW_PAGE_HELPER=Takes about 60 seconds
# REVIEW_PAGE_FOOTER=Ramos James Law, PLLC · Austin, TX
# REVIEW_PAGE_LOGO_URL=https://www.ramosjames.com/path/to/logo.png
# REVIEW_PAGE_LAURA_IMAGE=https://www.ramosjames.com/path/to/laura.jpg
# REVIEW_PAGE_TEXT_NUMBER=+15128723341
# REVIEW_PAGE_CALL_NUMBER=+15128723341
# REVIEW_PAGE_BRAND_COLOR=#0A1C40
# REVIEW_PAGE_ACCENT=#F5218B
# REVIEW_PAGE_CTA_COLOR=#45C7F0
